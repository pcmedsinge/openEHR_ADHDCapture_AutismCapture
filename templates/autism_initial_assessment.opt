                                                    <items id="text">Sensory motor score</items>
                                                    <items id="description"></items>
                                                </term_definitions>
                                                <term_definitions code="at0405">
                                                    <items id="text">Circumscribed interests score</items>
                                                    <items id="description"></items>
                                                </term_definitions>
                                                <term_definitions code="at0406">
                                                    <items id="text">Total score</items>
                                                    <items id="description"></items>
