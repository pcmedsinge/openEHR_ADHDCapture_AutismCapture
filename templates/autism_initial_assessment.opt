                                                <term_definitions code="at0402">
                                                    <items id="text">Social relatedness score</items>
                                                    <items id="description"></items>
                                                </term_definitions>
                                                <term_definitions code="at0403">
                                                    <items id="text">Language score</items>
                                                    <items id="description"></items>
