                                                <term_definitions code="at0000">
                                                    <items id="text">comorbidity_screening</items>
                                                    <items id="description">Structured screening for conditions commonly co-occurring with ADHD and Autism. Required by NICE NG87 Section 1.3.4 and NG142 Section 1.2.6.</items>
                                                    <items id="comment">Use cross_condition_screen for ASD screen on ADHD form and ADHD screen on Autism form. Not for confirmed diagnoses — use problem_diagnosis for those.</items>
