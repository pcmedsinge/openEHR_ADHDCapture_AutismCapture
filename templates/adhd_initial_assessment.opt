                                                <archetype_id>
                                                    <value>openEHR-EHR-CLUSTER.functional_impact_.v0</value>
                                                </archetype_id>
                                                <term_definitions code="at0000">
                                                    <items id="text">functional_impact</items>
                                                    <items id="description">Records degree of functional impairment across life domains as required by NICE NG87 Section 1.3 and NG142 Section 1.2. Each domain rated on a 4-point severity scale to support AQL aggregation in cohort 
  analytics</items>
                                                    <items id="comment">Use in Section 6 of both ADHDCapture and AutismCapture templates. Global functional impairment is a clinician summary rating — not derived automatically from domain scores</items>
                                                </term_definitions>
