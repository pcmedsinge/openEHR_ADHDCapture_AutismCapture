                                                <archetype_id>
                                                    <value>openEHR-EHR-CLUSTER.asrs_v11_screener.v0</value>
                                                </archetype_id>
                                                <term_definitions code="at0000">
                                                    <items id="text">asrs_v11_screener</items>
                                                    <items id="description">18-item WHO ADHD Self-Report Scale v1.1 (ASRS-v1.1). Items 1-6 form Part A — a score of 4 or more on Part A is a positive screen indicating high probability of ADHD and warrants full diagnostic interview. 
  Items 7-18 form Part B providing additional symptom detail.</items>
                                                    <items id="comment">Use in ADHDCapture template only. Part A positive screen flag should be auto-calculated from Item 1-6 scores in the application layer. Scores reflect frequency: 0=Never, 1=Rarely, 2=Sometimes, 3=Often, 4=Very     
  Often.      </items>
                                                </term_definitions>
