                                                <archetype_id>
                                                    <value>openEHR-EHR-CLUSTER.developmental_history.v0</value>
                                                </archetype_id>
                                                <term_definitions code="at0000">
                                                    <items id="text">developmental_history</items>
                                                    <items id="description"> Captures childhood developmental evidence required by NICE NG87 (ADHD) and NG142 (Autism) to establish neurodevelopmental onset. Informant field is mandatory — self-report-only history has a different diagnostic weight than   
  corroborated history.                                                                                                                                                                                                           
                          </items>
                                                    <items id="comment">Use in Section 5 of both ADHDCapture and AutismCapture templates. Not for recording current adult functional status — use the functional_impact cluster for that.

  Leave Bindings empty. Then click Save in the top navbar.

  Also updating the BUILD_GUIDE to correct the metadata steps.</items>
                                                </term_definitions>
